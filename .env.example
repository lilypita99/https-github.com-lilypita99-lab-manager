# Copy this file to .env and replace with your real values.
# Example: cp .env.example .env

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Use your deployed frontend URL in production. For a single-container deploy,
# set this to your public app URL, for example https://labflow.onrender.com
FRONTEND_URL=http://localhost:3000

# Frontend API base URL for Vercel or other separate frontend hosting.
# Example: REACT_APP_API_BASE_URL=https://labflow-backend.onrender.com
REACT_APP_API_BASE_URL=http://localhost:5003

# Optional production database override.
# Example: DATABASE_URL=sqlite:////data/lab_manager.db
# DATABASE_URL=

LABFLOW_SMTP_HOST=smtp.gmail.com
LABFLOW_SMTP_PORT=587
LABFLOW_SMTP_USER=your_email@gmail.com
LABFLOW_SMTP_PASS=your_16_char_app_password
LABFLOW_SMTP_FROM="LabFlow <your_email@gmail.com>"
LABFLOW_SMTP_USE_TLS=true

# Optional runtime port override
# PORT=5003
